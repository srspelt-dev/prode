# ===== MongoDB =====
# Local (docker-compose): mongodb://localhost:27017/prode
# Atlas:                  mongodb+srv://user:pass@cluster.mongodb.net/prode
MONGODB_URI=mongodb://localhost:27017/prode
MONGODB_DB=prode

# ===== Auth (JWT) =====
# Generá uno con: openssl rand -base64 32
JWT_SECRET=cambiame_por_un_secreto_largo_y_aleatorio
JWT_EXPIRY_HOURS=72

# Email del usuario que tendrá rol admin (puede cargar resultados y forzar sync)
ADMIN_EMAIL=admin@tudominio.com

# ===== football-data.org =====
# Plan gratuito incluye la Copa del Mundo 2026 (competición WC). Límite 10 req/min.
# Registrate gratis en https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=tu_token_aqui
FOOTBALL_DATA_BASE=https://api.football-data.org/v4
FOOTBALL_DATA_COMPETITION=WC

# ===== Cron =====
# Secreto que protege el endpoint /api/cron/sync (Vercel Cron lo manda como Bearer)
CRON_SECRET=otro_secreto_para_el_cron

# ===== Push (Web Push / VAPID) =====
# Generá las claves con: node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tu@email.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
